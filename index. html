<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>SuperCalc Pro · Ultimate</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <!-- HEADER -->
        <header class="main-header">
            <h1>⚡ SuperCalc Pro</h1>
            <button class="theme-btn" id="themeToggle">🌙 Gelap</button>
        </header>

        <!-- LAYOUT UTAMA: KALKULATOR + RIWAYAT -->
        <div class="main-layout">
            <!-- PANEL KIRI (KALKULATOR & FITUR) -->
            <section class="left-panel">
                <!-- LAYAR UTAMA -->
                <div class="display-wrapper">
                    <div class="expr-preview" id="exprPreview"></div>
                    <input type="text" id="display" class="main-display" readonly value="0">
                </div>

                <!-- TOMBOL MEMORI -->
                <div class="memory-bar">
                    <button class="mem-btn" id="mc">MC</button>
                    <button class="mem-btn" id="mr">MR</button>
                    <button class="mem-btn" id="mPlus">M+</button>
                    <button class="mem-btn" id="mMinus">M-</button>
                </div>

                <!-- TAB NAVIGASI -->
                <div class="tab-nav">
                    <button class="tab-btn active" data-tab="calc">🧮 Kalkulator</button>
                    <button class="tab-btn" data-tab="convert">📏 Konversi</button>
                    <button class="tab-btn" data-tab="finance">💰 Keuangan</button>
                    <button class="tab-btn" data-tab="tools">🛠️ Tools</button>
                </div>

                <!-- PANEL KALKULATOR ILMIAH (default tampil) -->
                <div id="calcPanel" class="tab-panel active-panel">
                    <div class="scientific-keypad">
                        <!-- Baris 1: fungsi lanjutan -->
                        <button data-action="sin">sin</button>
                        <button data-action="cos">cos</button>
                        <button data-action="tan">tan</button>
                        <button data-action="asin">asin</button>
                        <button data-action="acos">acos</button>
                        <button data-action="atan">atan</button>
                        <button data-action="sinh">sinh</button>
                        <button data-action="cosh">cosh</button>
                        <button data-action="tanh">tanh</button>
                        <button data-action="log">log</button>
                        <button data-action="ln">ln</button>
                        <button data-action="sqrt">√</button>
                        <button data-action="cbrt">∛</button>
                        <button data-action="square">x²</button>
                        <button data-action="cube">x³</button>
                        <button data-action="pow">x^y</button>
                        <button data-action="fact">n!</button>
                        <button data-action="pi">π</button>
                        <button data-action="e">e</button>
                        <button data-action="inv">1/x</button>
                        <button data-action="abs">|x|</button>
                        <button data-action="exp">exp</button>
                        <button data-action="mod">mod</button>
                        <button data-action="(">(</button>
                        <button data-action=")">)</button>
                        <button data-action="degRad" id="degRadToggle" class="mode-btn">DEG</button>

                        <!-- Baris angka & operator dasar -->
                        <button data-action="7">7</button>
                        <button data-action="8">8</button>
                        <button data-action="9">9</button>
                        <button data-action="del" class="operator">DEL</button>
                        <button data-action="C" class="operator">C</button>
                        <button data-action="4">4</button>
                        <button data-action="5">5</button>
                        <button data-action="6">6</button>
                        <button data-action="*" class="operator">×</button>
                        <button data-action="/" class="operator">÷</button>
                        <button data-action="1">1</button>
                        <button data-action="2">2</button>
                        <button data-action="3">3</button>
                        <button data-action="+" class="operator">+</button>
                        <button data-action="-" class="operator">−</button>
                        <button data-action="0">0</button>
                        <button data-action=".">.</button>
                        <button data-action="±">+/-</button>
                        <button data-action="%" class="operator">%</button>
                        <button data-action="=" class="equal" colspan="2">=</button>
                    </div>
                </div>

                <!-- PANEL KONVERSI SATUAN -->
                <div id="convertPanel" class="tab-panel extra-panel">
                    <h3 class="panel-title">📏 Konversi Satuan</h3>
                    <div class="converter-grid">
                        <!-- Panjang -->
                        <div class="conv-card">
                            <label>Panjang</label>
                            <input type="number" id="lengthIn" placeholder="Nilai">
                            <div class="conv-row">
                                <select id="lengthFrom">
                                    <option value="mm">mm</option><option value="cm">cm</option><option value="m">m</option><option value="km">km</option>
                                </select>
                                <span>→</span>
                                <select id="lengthTo">
                                    <option value="mm">mm</option><option value="cm">cm</option><option value="m">m</option><option value="km">km</option>
                                </select>
                            </div>
                            <div class="conv-result">
                                <input type="text" id="lengthOut" readonly placeholder="Hasil">
                                <button class="calc-btn" id="convertLength">Konversi</button>
                            </div>
                        </div>
                        <!-- Berat -->
                        <div class="conv-card">
                            <label>Berat</label>
                            <input type="number" id="weightIn" placeholder="Nilai">
                            <div class="conv-row">
                                <select id="weightFrom">
                                    <option value="mg">mg</option><option value="g">g</option><option value="kg">kg</option><option value="ton">ton</option>
                                </select>
                                <span>→</span>
                                <select id="weightTo">
                                    <option value="mg">mg</option><option value="g">g</option><option value="kg">kg</option><option value="ton">ton</option>
                                </select>
                            </div>
                            <div class="conv-result">
                                <input type="text" id="weightOut" readonly placeholder="Hasil">
                                <button class="calc-btn" id="convertWeight">Konversi</button>
                            </div>
                        </div>
                        <!-- Suhu -->
                        <div class="conv-card">
                            <label>Suhu</label>
                            <input type="number" id="tempIn" placeholder="Nilai">
                            <div class="conv-row">
                                <select id="tempFrom">
                                    <option value="C">°C</option><option value="F">°F</option><option value="K">K</option>
                                </select>
                                <span>→</span>
                                <select id="tempTo">
                                    <option value="C">°C</option><option value="F">°F</option><option value="K">K</option>
                                </select>
                            </div>
                            <div class="conv-result">
                                <input type="text" id="tempOut" readonly placeholder="Hasil">
                                <button class="calc-btn" id="convertTemp">Konversi</button>
                            </div>
                        </div>
                        <!-- Waktu -->
                        <div class="conv-card">
                            <label>Waktu</label>
                            <input type="number" id="timeIn" placeholder="Nilai">
                            <div class="conv-row">
                                <select id="timeFrom">
                                    <option value="s">detik</option><option value="min">menit</option><option value="h">jam</option><option value="d">hari</option>
                                </select>
                                <span>→</span>
                                <select id="timeTo">
                                    <option value="s">detik</option><option value="min">menit</option><option value="h">jam</option><option value="d">hari</option>
                                </select>
                            </div>
                            <div class="conv-result">
                                <input type="text" id="timeOut" readonly placeholder="Hasil">
                                <button class="calc-btn" id="convertTime">Konversi</button>
                            </div>
                        </div>
                        <!-- Kecepatan -->
                        <div class="conv-card">
                            <label>Kecepatan</label>
                            <input type="number" id="speedIn" placeholder="Nilai">
                            <div class="conv-row">
                                <select id="speedFrom">
                                    <option value="kmh">km/h</option><option value="ms">m/s</option>
                                </select>
                                <span>→</span>
                                <select id="speedTo">
                                    <option value="kmh">km/h</option><option value="ms">m/s</option>
                                </select>
                            </div>
                            <div class="conv-result">
                                <input type="text" id="speedOut" readonly placeholder="Hasil">
                                <button class="calc-btn" id="convertSpeed">Konversi</button>
                            </div>
                        </div>
                        <!-- Data digital -->
                        <div class="conv-card">
                            <label>Data digital</label>
                            <input type="number" id="dataIn" placeholder="Nilai">
                            <div class="conv-row">
                                <select id="dataFrom">
                                    <option value="B">B</option><option value="KB">KB</option><option value="MB">MB</option><option value="GB">GB</option><option value="TB">TB</option>
                                </select>
                                <span>→</span>
                                <select id="dataTo">
                                    <option value="B">B</option><option value="KB">KB</option><option value="MB">MB</option><option value="GB">GB</option><option value="TB">TB</option>
                                </select>
                            </div>
                            <div class="conv-result">
                                <input type="text" id="dataOut" readonly placeholder="Hasil">
                                <button class="calc-btn" id="convertData">Konversi</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PANEL KEUANGAN -->
                <div id="financePanel" class="tab-panel extra-panel">
                    <h3 class="panel-title">💰 Keuangan</h3>
                    <div class="finance-grid">
                        <div class="finance-card">
                            <label>Diskon</label>
                            <input type="number" id="discountPrice" placeholder="Harga asli">
                            <input type="number" id="discountPercent" placeholder="Diskon %">
                            <button class="calc-btn" id="calcDiscount">Hitung</button>
                            <span class="result-badge" id="discountResult">0</span>
                        </div>
                        <div class="finance-card">
                            <label>Pajak</label>
                            <input type="number" id="taxAmount" placeholder="Jumlah">
                            <input type="number" id="taxRate" placeholder="Pajak %">
                            <button class="calc-btn" id="calcTax">Total + Pajak</button>
                            <span class="result-badge" id="taxResult">0</span>
                        </div>
                        <div class="finance-card">
                            <label>Keuntungan</label>
                            <input type="number" id="profitCost" placeholder="Modal">
                            <input type="number" id="profitSell" placeholder="Jual">
                            <button class="calc-btn" id="calcProfit">% Untung</button>
                            <span class="result-badge" id="profitResult">0%</span>
                        </div>
                        <div class="finance-card">
                            <label>Bunga sederhana</label>
                            <input type="number" id="simplePrincipal" placeholder="Pokok">
                            <input type="number" id="simpleRate" placeholder="Bunga % per tahun">
                            <input type="number" id="simpleTime" placeholder="Tahun">
                            <button class="calc-btn" id="calcSimple">Hitung bunga</button>
                            <span class="result-badge" id="simpleResult">0</span>
                        </div>
                        <div class="finance-card">
                            <label>Bagi tagihan + tip</label>
                            <input type="number" id="billTotal" placeholder="Total tagihan">
                            <input type="number" id="billPeople" placeholder="Jumlah orang">
                            <input type="number" id="billTip" placeholder="Tip %">
                            <button class="calc-btn" id="calcSplit">Per orang</button>
                            <span class="result-badge" id="splitResult">0</span>
                        </div>
                        <div class="finance-card">
                            <label>Pinjaman (cicilan bulanan)</label>
                            <input type="number" id="loanAmount" placeholder="Jumlah pinjaman">
                            <input type="number" id="loanRate" placeholder="Suku bunga % tahun">
                            <input type="number" id="loanYears" placeholder="Tenor (tahun)">
                            <button class="calc-btn" id="calcLoan">Cicilan/bulan</button>
                            <span class="result-badge" id="loanResult">0</span>
                        </div>
                    </div>
                </div>

                <!-- PANEL TOOLS -->
                <div id="toolsPanel" class="tab-panel extra-panel">
                    <h3 class="panel-title">🛠️ Alat Bantu</h3>
                    <div class="tools-grid">
                        <div class="tool-card">
                            <label>Kalkulator umur</label>
                            <input type="date" id="birthDate">
                            <button class="calc-btn" id="calcAge">Hitung umur</button>
                            <span class="result-badge" id="ageResult"></span>
                        </div>
                        <div class="tool-card">
                            <label>BMI</label>
                            <input type="number" id="weightKg" placeholder="Berat (kg)">
                            <input type="number" id="heightCm" placeholder="Tinggi (cm)">
                            <select id="gender">
                                <option value="male">Laki-laki</option>
                                <option value="female">Perempuan</option>
                            </select>
                            <button class="calc-btn" id="calcBmi">Hitung BMI</button>
                            <span class="result-badge" id="bmiResult"></span>
                        </div>
                        <div class="tool-card">
                            <label>% Kenaikan/Penurunan</label>
                            <input type="number" id="oldVal" placeholder="Nilai awal">
                            <input type="number" id="newVal" placeholder="Nilai baru">
                            <button class="calc-btn" id="calcChange">Hitung</button>
                            <span class="result-badge" id="changeResult"></span>
                        </div>
                        <div class="tool-card">
                            <label>Konversi mata uang (kurs tetap)</label>
                            <input type="number" id="currencyAmt" placeholder="Jumlah">
                            <div class="conv-row">
                                <select id="currencyFrom">
                                    <option value="IDR">IDR</option><option value="USD">USD</option><option value="EUR">EUR</option>
                                    <option value="GBP">GBP</option><option value="SGD">SGD</option><option value="MYR">MYR</option>
                                </select>
                                <span>→</span>
                                <select id="currencyTo">
                                    <option value="USD">USD</option><option value="IDR">IDR</option><option value="EUR">EUR</option>
                                    <option value="GBP">GBP</option><option value="SGD">SGD</option><option value="MYR">MYR</option>
                                </select>
                            </div>
                            <button class="calc-btn" id="convertCurrency">Konversi</button>
                            <span class="result-badge" id="currencyResult">0</span>
                        </div>
                        <div class="tool-card">
                            <label>Persentase (X dari Y)</label>
                            <input type="number" id="percX" placeholder="X">
                            <input type="number" id="percY" placeholder="Y">
                            <button class="calc-btn" id="calcPercentage">X adalah ?% dari Y</button>
                            <span class="result-badge" id="percResult">0%</span>
                        </div>
                        <div class="tool-card">
                            <label>Berapa % dari Z adalah W?</label>
                            <input type="number" id="percPart" placeholder="Bagian (W)">
                            <input type="number" id="percWhole" placeholder="Keseluruhan (Z)">
                            <button class="calc-btn" id="calcPartPercentage">Hitung %</button>
                            <span class="result-badge" id="partPercResult">0%</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PANEL KANAN: RIWAYAT -->
            <aside class="history-panel">
                <div class="history-header">
                    <span>📜 Riwayat</span>
                    <button id="clearHistory" class="clear-btn">Hapus semua</button>
                </div>
                <ul id="historyList" class="history-list">
                    <li class="history-placeholder">Belum ada riwayat</li>
                </ul>
            </aside>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>